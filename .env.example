# =============================================================================
# ENV-MUUTTUJAT — Gmail SMTP -reitti
# =============================================================================
#
# MIHIN ARVOT MENEVÄT:
#   1. Avaa https://claude.ai/code → projekti "Uutiskatsaus"
#   2. Settings → "Environment variables" / "Secrets"
#   3. Lisää alla olevat KEY=VALUE -parit
#
# LOKAALI TESTAUS: kopioi tämä tiedosto nimellä .env.local ja täytä arvot.
#   .env.local on .gitignored — ei vahingossa Githubiin.
# =============================================================================


# 1) Sinun Gmail-osoitteesi (lähettäjä)
GMAIL_USER=lauri.hynonen@gmail.com


# 2) Gmail App Password (EI tavallinen Gmail-salasana)
#    Hae täältä: https://myaccount.google.com/apppasswords
#    Vaatii 2FA:n päälle ensin: https://myaccount.google.com/security
#    Muoto: 16 merkkiä, voi sisältää välilyöntejä (skripti poistaa ne)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx


# 3) Vastaanottaja
BRIEFING_RECIPIENT=miskahirvo@gmail.com


# 4) (Valinnainen) Lähettäjän näyttönimi
# BRIEFING_FROM_NAME=Uutiskatsaus
