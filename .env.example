# =============================================================================
# ENV-MUUTTUJAT — kopioi näiden ARVOT Claude Code on the web -dashboardiin
# =============================================================================
#
# MIHIN:
#   1. Avaa https://claude.ai/code
#   2. Valitse projekti "Uutiskatsaus" (linkitä GitHub-repo jos uusi)
#   3. Klikkaa projektin asetukset (hammasratas / Settings)
#   4. Etsi osio "Environment variables" tai "Secrets"
#   5. Klikkaa "Add variable" ja syötä alla olevat KEY=VALUE -parit
#
# ÄLÄ koskaan committaa oikeita arvoja git-repoon. Tämä tiedosto on vain malli.
# =============================================================================


# 1) Resend API-avain — hae täältä: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# 2) Vastaanottaja
BRIEFING_RECIPIENT=miskahirvo@gmail.com


# 3) (Valinnainen) Lähettäjän osoite
#    Oletus: "Uutiskatsaus <onboarding@resend.dev>" — toimii heti ilman setupia.
#    Tuotantoon: verifioi oma domain Resendissä ja vaihda alla.
# BRIEFING_FROM=Uutiskatsaus <uutiset@oma-domain.fi>
